{
    "include": ["src/**/*.ts"],
    "compilerOptions": {
        "target": "ES6",
        "module": "ES6",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "outDir": "dist/Scripts",
        "rootDir": "src/",
        "moduleResolution": "bundler",
        "types": ["jest", "xrm"]
    }
}
